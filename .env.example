# =============================================================================
# QuickQuote CA — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Get these from: https://app.supabase.com → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Server only — never expose

# -----------------------------------------------------------------------------
# Anthropic (Claude Haiku)
# Get from: https://console.anthropic.com → API Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here   # Server only

# -----------------------------------------------------------------------------
# Resend (Email delivery)
# Get from: https://resend.com → API Keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your-key-here          # Server only
RESEND_FROM_EMAIL=quotes@quickquoteca.com

# -----------------------------------------------------------------------------
# Stripe
# Get from: https://dashboard.stripe.com → Developers → API Keys
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here   # Safe for browser
STRIPE_SECRET_KEY=sk_test_your-key-here                    # Server only
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here               # Server only
STRIPE_PRO_PRICE_ID=price_your-price-id-here               # $15 CAD/mo Pro plan

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
